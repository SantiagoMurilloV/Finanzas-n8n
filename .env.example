# Puerto donde corre el dashboard
PORT=3000

# URL pública que se mostrará en el dashboard como "Endpoint para n8n".
# - En local sin túnel: http://localhost:3000
# - Con ngrok: https://tu-subdominio.ngrok-free.app
# - Deploy en Render/Railway: https://tu-app.onrender.com
PUBLIC_URL=http://localhost:3000

# Token opcional para proteger el endpoint POST /api/movimientos.
# Si lo seteás, n8n debe mandar el header: Authorization: Bearer <este-token>
# Dejalo vacío para clase (más simple).
API_TOKEN=
